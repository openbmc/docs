        "id": 1000000
      },
      "writtenOn": "2026-06-02T11:21:38Z",
      "side": 1,
      "message": "You need documentation on _why_ these are good things and/or expected things for a BMC to add firewall behaviors for.",
      "range": {
        "startLine": 20,
        "startChar": 0,
        "endLine": 25,
        "endChar": 40
      },
      "revId": "e8e6b143abe6d3e5ee82f0b4952b532558537aa0",
